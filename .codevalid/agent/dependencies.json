{
  "dependencies": [
    {
      "name": "postgres",
      "kind": "database",
      "image": "postgres:16",
      "listen": "toxiproxy:5432",
      "upstream": "postgres:5432",
      "env_var": "DATABASE_URL"
    },
    {
      "name": "thirdparty",
      "kind": "http_api",
      "image": "wiremock/wiremock:3.13.1",
      "listen": "toxiproxy:8080",
      "upstream": "wiremock:8080",
      "env_var": "THIRDPARTY_BASE_URL"
    }
  ]
}
